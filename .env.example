# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron
# Use a long random value. Vercel sends it as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# WhatsApp Cloud API (Meta)
# Used by automatic promotions and appointment reminders.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0

# WhatsApp templates approved in Meta.
# Required in production for proactive/bulk messages outside the 24-hour window.
WHATSAPP_PROMO_TEMPLATE_NAME=
WHATSAPP_PROMO_TEMPLATE_LANG=es
WHATSAPP_CITA_TEMPLATE_NAME=
WHATSAPP_CITA_TEMPLATE_LANG=es

# Promotions email provider. Resend is preferred when both providers are configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
PROMOCIONES_EMAIL_FROM=
