# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Encuesta de satisfacción por defecto (Google Forms, Microsoft Forms, etc.)
NEXT_PUBLIC_ENCUESTA_URL=https://forms.gle/tu-encuesta
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron
# Use a long random value. Vercel sends it as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# WhatsApp Cloud API (Meta) — proveedor oficial, cobra por conversación
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# IDs por línea (multi-número agentes IA)
WHATSAPP_PHONE_ID_PRINCIPAL=
WHATSAPP_PHONE_ID_SUCURSAL=
WHATSAPP_PHONE_ID_CORPORATIVO=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_PROMO_TEMPLATE_NAME=
WHATSAPP_PROMO_TEMPLATE_LANG=es
WHATSAPP_CITA_TEMPLATE_NAME=
WHATSAPP_CITA_TEMPLATE_LANG=es

# Evolution API — WhatsApp Web en servidor propio (~$5/mes DigitalOcean)
# Documentación: https://doc.evolution-api.com/
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
# Lote máximo por ejecución (recomendado 20-50) y pausa entre mensajes en ms (mín. 2000)
EVOLUTION_BATCH_SIZE=25
EVOLUTION_DELAY_MS=4000

# Promotions email provider. Resend is preferred when both providers are configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
PROMOCIONES_EMAIL_FROM=

# ── Agentes IA (WhatsApp / Messenger) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENTES_WEBHOOK_SECRET=
# App Secret de Meta (Configuración básica de la app) — valida webhooks
META_APP_SECRET=
AGENTES_API_KEY=
AGENTES_UMBRAL_CONFIANZA=0.55
AGENTES_HISTORIAL_MAX=20
# Producción: false (respeta horario clínica). Local: true para probar de noche
AGENTES_IGNORAR_HORARIO=false
# Producción: false (oculta /agentes/prueba). Local: true si necesita la página
AGENTES_PRUEBA_ENABLED=false
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
