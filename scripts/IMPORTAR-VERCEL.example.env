# Copiar a Vercel → Settings → Environment Variables → Import .env
# Pegar valores reales desde .env.local (NO subir este archivo con secretos a GitHub)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
